# Expansion Scout — on-device Gemma configuration.
# Copy to `.env` and adjust. All vars are EXPO_PUBLIC_* so Metro inlines them.
# The app runs with ZERO config; every var has a default.

# Which reasoning transport to use:
#   auto   (default) device: embedded llama.rn → Ollama; web: Ollama
#   llama  force embedded llama.rn (true on-device; needs a dev build + a device)
#   ollama force the local HTTP runtime (dev / iOS Simulator over LAN)
EXPO_PUBLIC_GEMMA_TRANSPORT=auto

# Set to "false" to force the deterministic fallback (e.g. a fully offline safe demo).
EXPO_PUBLIC_GEMMA_ENABLED=true

# Per-call timeout (ms). Cold start loads the model; keep generous.
EXPO_PUBLIC_GEMMA_TIMEOUT_MS=22000

# ── Embedded transport (llama.rn, on-device) ────────────────────────────────
# GGUF weights are downloaded to the device on first run (never bundled).
# Default: Google's official Gemma 4 E2B QAT Q4_0 — sized for iPhone 17.
EXPO_PUBLIC_GEMMA_GGUF_URL=https://huggingface.co/google/gemma-4-E2B-it-qat-q4_0-gguf/resolve/main/gemma-4-E2B_q4_0-it.gguf
EXPO_PUBLIC_GEMMA_GGUF_FILE=gemma-4-E2B_q4_0-it.gguf
# Context window and GPU offload. 99 = offload all layers to Metal.
EXPO_PUBLIC_GEMMA_N_CTX=4096
EXPO_PUBLIC_GEMMA_N_GPU_LAYERS=99

# ── Ollama transport (dev / simulator) ──────────────────────────────────────
# Base URL of the local Ollama-compatible HTTP runtime.
#   • iOS Simulator / web / Android emulator on the same Mac: localhost works.
#   • Physical device: set to the host Mac's LAN IP, e.g. http://192.168.1.42:11434
EXPO_PUBLIC_GEMMA_BASE_URL=http://localhost:11434
# The Ollama model tag. Pull it once:  ollama pull gemma4:e2b-it-qat
EXPO_PUBLIC_GEMMA_MODEL=gemma4:e2b-it-qat
